# JARVIS Environment Configuration
# Copy this file to .env and fill in your values.
# Place .env inside the jarvis/ directory (alongside main.py).

# ── Required ──────────────────────────────────────────────────────────────────
GROQ_API_KEY="your_groq_api_key_here"
# Get your free key at: https://console.groq.com

# ── Optional: LLM Provider (default: groq) ───────────────────────────────────
# LLM_PROVIDER=groq                        # "groq" | "openai"
# LLM_MODEL=llama-3.3-70b-versatile        # Groq model name
# LLM_TEMPERATURE=0                        # 0 = deterministic, 1 = creative
# LLM_MAX_TOKENS=1600                      # Max output tokens per response

# ── Optional: OpenAI (only if LLM_PROVIDER=openai) ───────────────────────────
# OPENAI_API_KEY="your_openai_key_here"
# LLM_MODEL=gpt-4o                         # OpenAI model name
